APP_ENV=local
DATABASE_URL=postgresql://local_agent:change_me@127.0.0.1:5432/local_data_agent
MODEL_PROVIDER=local
MODEL_API_KEY=change_me
MODEL_BASE_URL=http://127.0.0.1:11434/v1
MODEL_NAME=qwen2.5-coder:3b
MODEL_TIMEOUT_SECONDS=30
MODEL_MAX_RETRIES=1
MODEL_SQL_GENERATOR_ENABLED=true
SQL_MAX_ROWS=30
SQL_STATEMENT_TIMEOUT_MS=15000
SQL_LOCK_TIMEOUT_MS=3000
INTENT_PARSER_ENABLED=true
INTENT_MODEL_PROVIDER=local
INTENT_MODEL_API_KEY=change_me
INTENT_MODEL_BASE_URL=http://127.0.0.1:11434/v1
INTENT_MODEL_NAME=qwen2.5-coder:7b
INTENT_MODEL_TIMEOUT_SECONDS=10
INTENT_MODEL_MAX_RETRIES=1
EMBEDDING_PROVIDER=aliyun
EMBEDDING_API_KEY=change_me
EMBEDDING_BASE_URL=https://dashscope.aliyuncs.com/compatible-mode/v1
EMBEDDING_MODEL=text-embedding-v4
EMBEDDING_DIMENSIONS=1536
EMBEDDING_TIMEOUT_SECONDS=30
EMBEDDING_MAX_RETRIES=1
AUTH_REQUIRED=false
AUTH_ALLOW_SELF_REGISTRATION=false
AUTH_SESSION_IDLE_HOURS=12
AUTH_SESSION_ABSOLUTE_DAYS=7
AUTH_COOKIE_NAME=local_data_agent_session
AUTH_CSRF_COOKIE_NAME=local_data_agent_csrf
AUTH_COOKIE_SECURE=false
AUTH_DEV_USER_EMAIL=local-admin@localhost
REDIS_URL=redis://127.0.0.1:6379/0
CONVERSATION_RETENTION_HOURS=72
CONVERSATION_MESSAGE_LIMIT=200
CONVERSATION_CONTEXT_TOKEN_BUDGET=8000
CONVERSATION_OUTPUT_TOKEN_RESERVE=1000
CONVERSATION_COMPRESSION_LIGHT_WATERMARK=0.6
CONVERSATION_COMPRESSION_AGGRESSIVE_WATERMARK=0.8
CONVERSATION_SUMMARY_CHAR_LIMIT=6000
AUTH_LOGIN_RATE_LIMIT_PER_15_MINUTES=10
AUTH_REGISTER_RATE_LIMIT_PER_HOUR=5
